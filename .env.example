# База данных
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-database-password
POSTGRES_DB=nl_table
DATABASE_URL=postgresql+asyncpg://postgres:change-this-database-password@postgres:5432/nl_table

# JWT секреты
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://redis:6379/0

# Wildberries API
WB_API_BASE_URL=https://suppliers-api.wildberries.ru

# Шифрование
ENCRYPTION_KEY=your-32-byte-encryption-key

# APP
APP_NAME=NL Table API
APP_VERSION=1.0.0
DEBUG=False

# Docker/deployment
COMPOSE_PROJECT_NAME=nl-backend
APP_BIND_HOST=0.0.0.0
APP_PORT=8000
POSTGRES_BIND_HOST=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND_HOST=127.0.0.1
REDIS_PORT=6379
POSTGRES_VOLUME_NAME=nl-backend_postgres_data
