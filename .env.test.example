# Copy to .env.test and replace every value marked "change-me".
POSTGRES_PASSWORD=change-me
SECRET_KEY=change-me
ENCRYPTION_KEY=change-me

DATABASE_URL=postgresql+asyncpg://postgres:change-me@postgres:5432/nl_table_test
REDIS_URL=redis://redis:6379/0
WB_API_BASE_URL=http://127.0.0.1:9

APP_NAME=NL Table API (test)
APP_VERSION=1.0.0-test
DEBUG=False
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

TEST_APP_BIND=127.0.0.1
TEST_APP_PORT=18000
